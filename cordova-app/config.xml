<?xml version='1.0' encoding='utf-8'?>
<widget id="io.accessnetwork.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>Access Network</name>
    <description>
        Access Network - Earn cryptocurrency by mining ACCESS tokens. Connect your wallet and start earning today!
    </description>
    <author email="support@access-network.io" href="https://access-network.io">
        Access Network Team
    </author>
    <content src="index.html" />
    
    <!-- Hook: fix splash screen (no circle around icon) -->
    <hook type="after_prepare" src="hooks/after_prepare/fix_splash_theme.js" />
    
    <!-- Hook: patch FCM plugin for transaction logo (small icon on left) -->
    <hook type="after_prepare" src="hooks/after_prepare/patch_fcm_logo.js" />
    
    <!-- Allow access to server API -->
    <access origin="https://accesschain.org" />
    <access origin="https://access-network.io" />
    <access origin="*" />
    
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    
    <!-- ==================== iOS Platform ==================== -->
    <platform name="ios">
        <!-- iOS Icons - generated from 512px source in CI to exact required sizes -->
        <icon src="res/ios-icons/icon-1024.png" width="1024" height="1024" />
        <icon src="res/ios-icons/icon-180.png" width="180" height="180" />
        <icon src="res/ios-icons/icon-167.png" width="167" height="167" />
        <icon src="res/ios-icons/icon-152.png" width="152" height="152" />
        <icon src="res/ios-icons/icon-120.png" width="120" height="120" />
        <icon src="res/ios-icons/icon-87.png" width="87" height="87" />
        <icon src="res/ios-icons/icon-80.png" width="80" height="80" />
        <icon src="res/ios-icons/icon-76.png" width="76" height="76" />
        <icon src="res/ios-icons/icon-60.png" width="60" height="60" />
        <icon src="res/ios-icons/icon-58.png" width="58" height="58" />
        <icon src="res/ios-icons/icon-40.png" width="40" height="40" />
        <icon src="res/ios-icons/icon-29.png" width="29" height="29" />
        <icon src="res/ios-icons/icon-20.png" width="20" height="20" />

        <!-- Deployment Target -->
        <preference name="deployment-target" value="14.0" />
        <preference name="SwiftVersion" value="5.0" />

        <!-- ✅ CRITICAL: Bundle GoogleService-Info.plist for Firebase -->
        <resource-file src="GoogleService-Info.plist" />

        <!-- ✅ CRITICAL: iOS must use 'app' scheme (not 'http') -->
        <!-- cordova-ios 7.x removed GCDWebServer, so http://localhost won't work -->
        <!-- 'app://localhost' uses WKURLSchemeHandler to serve local files -->
        <preference name="scheme" value="app" />
        <preference name="hostname" value="localhost" />

        <!-- WKWebView Settings -->
        <preference name="WKWebViewOnly" value="true" />
        <preference name="CordovaWebViewEngine" value="CDVWKWebViewEngine" />
        <preference name="WKFrameSetContentInsetAdjustmentAutomatic" value="true" />
        
        <!-- Allow mixed content for API calls -->
        <preference name="AllowBackForwardNavigationGestures" value="false" />
        
        <!-- Prevent new windows / popups that crash WKWebView -->
        <preference name="AllowNewWindows" value="false" />
        
        <!-- Don't limit navigations to app-bound domains (API calls need external access) -->
        <preference name="LimitsNavigationsToAppBoundDomains" value="false" />

        <!-- iOS Permissions - displayed in permission dialogs -->
        <config-file parent="NSCameraUsageDescription" target="*-Info.plist">
            <string>Access Network needs camera access to scan QR codes for wallet addresses</string>
        </config-file>
        <config-file parent="NSFaceIDUsageDescription" target="*-Info.plist">
            <string>Access Network uses Face ID to unlock the app securely</string>
        </config-file>
        <config-file parent="NSUserTrackingUsageDescription" target="*-Info.plist">
            <string>This identifier will be used to deliver personalized ads to you</string>
        </config-file>
        
        <!-- Background modes for push notifications -->
        <config-file parent="UIBackgroundModes" target="*-Info.plist">
            <array>
                <string>remote-notification</string>
            </array>
        </config-file>

        <!-- Allow HTTP traffic for API server -->
        <config-file parent="NSAppTransportSecurity" target="*-Info.plist">
            <dict>
                <key>NSAllowsArbitraryLoads</key>
                <true />
            </dict>
        </config-file>

        <!-- Status bar -->
        <preference name="StatusBarStyle" value="lightcontent" />

        <!-- Firebase auto-configuration enabled (default YES) -->
        <!-- GADDelayAppMeasurementInit removed - AdMob not used on iOS -->
    </platform>

    <!-- ==================== Android Platform ==================== -->
    <!-- Android specific -->
    <platform name="android">
        <!-- ✅ CRITICAL: Android uses HTTP scheme to allow mixed content -->
        <preference name="scheme" value="http" />
        <preference name="hostname" value="localhost" />
        
        <icon src="www/access-store-192.png" density="xxxhdpi" />
        <icon src="www/access-store-144.png" density="xxhdpi" />
        <icon src="www/access-store-96.png" density="xhdpi" />
        <icon src="www/access-store-72.png" density="hdpi" />
        <icon src="www/access-store-48.png" density="mdpi" />
        
        <!-- Splash Screen Icon (Android 12+ API) -->
        <preference name="AndroidWindowSplashScreenAnimatedIcon" value="www/splash-text.png" />
        <preference name="AndroidWindowSplashScreenBackground" value="#ffffff" />
        
        <preference name="android-minSdkVersion" value="24" />
        <preference name="android-targetSdkVersion" value="34" />
        <preference name="android-compileSdkVersion" value="34" />
        <preference name="AndroidXAppCompatVersion" value="1.6.1" />
        
        <!-- ✅ CRITICAL: Allow HTTP traffic (cleartext) for API server -->
        <edit-config file="app/src/main/AndroidManifest.xml" mode="merge" target="/manifest/application">
            <application android:usesCleartextTraffic="true" android:networkSecurityConfig="@xml/network_security_config" />
        </edit-config>
        
        <!-- ✅ Notification icon (white silhouette, no background) -->
        <config-file parent="/manifest/application" target="AndroidManifest.xml">
            <meta-data android:name="com.google.firebase.messaging.default_notification_icon" android:resource="@drawable/ic_notification" />
            <meta-data android:name="com.google.firebase.messaging.default_notification_color" android:resource="@color/cdv_splashscreen_background" />
        </config-file>
        <resource-file src="res/xml/network_security_config.xml" target="app/src/main/res/xml/network_security_config.xml" />
        
        <!-- ✅ Android Permissions for Camera and other features -->
        <config-file parent="/*" target="AndroidManifest.xml">
            <uses-permission android:name="android.permission.CAMERA" />
            <uses-permission android:name="android.permission.INTERNET" />
            <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
            <uses-permission android:name="android.permission.USE_BIOMETRIC" />
            <uses-feature android:name="android.hardware.camera" android:required="false" />
            <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />
        </config-file>
    </platform>
    
    <!-- Preferences -->
    <preference name="DisallowOverscroll" value="true" />
    <preference name="BackgroundColor" value="0xff1a1a2e" />
    <preference name="StatusBarBackgroundColor" value="#1a1a2e" />
    <preference name="StatusBarStyle" value="lightcontent" />
    <preference name="StatusBarOverlaysWebView" value="false" />
    <preference name="Orientation" value="portrait" />
    <preference name="Fullscreen" value="false" />
    <preference name="KeepRunning" value="true" />
    
    <!-- MixedContentMode and AllowInsecureLocalhost are Android-only -->
    <preference name="MixedContentMode" value="0" />
    <preference name="AllowInsecureLocalhost" value="true" />
    
    <!-- Splash Screen Settings -->
    <preference name="SplashScreenDelay" value="2000" />
    <preference name="AutoHideSplashScreen" value="true" />
    <preference name="ShowSplashScreenSpinner" value="false" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="500" />
    <preference name="SplashMaintainAspectRatio" value="true" />
    <preference name="SplashShowOnlyFirstTime" value="false" />
    
    <!-- Google Sign-In Plugin - Web Client ID (required for Android) -->
    <plugin name="cordova-plugin-googleplus" spec="^8.5.2">
        <variable name="WEB_APPLICATION_CLIENT_ID" value="586936149662-ja0tlfjfinl2sl17j9ntp3m1avnf3dhn.apps.googleusercontent.com" />
        <variable name="REVERSED_CLIENT_ID" value="com.googleusercontent.apps.586936149662-ja0tlfjfinl2sl17j9ntp3m1avnf3dhn" />
    </plugin>
    
    <!-- ✅ StatusBar Plugin -->
    <plugin name="cordova-plugin-statusbar" spec="^4.0.0" />
    
    <!-- ✅ Camera Plugin -->
    <plugin name="cordova-plugin-camera" spec="^8.0.0" />
    
    <!-- ✅ Android Permissions Plugin (for runtime permission requests) -->
    <plugin name="cordova-plugin-android-permissions" spec="^1.1.5" />
    
    <!-- ✅ Clipboard Plugin -->
    <plugin name="cordova-clipboard" spec="^1.3.0" />
    
    <!-- ✅ Firebase Cloud Messaging for Push Notifications -->
    <plugin name="cordova-plugin-firebase-messaging" spec="^6.1.0">
        <variable name="FIREBASE_ANALYTICS_COLLECTION_ENABLED" value="false" />
        <variable name="FIREBASE_PERFORMANCE_COLLECTION_ENABLED" value="false" />
        <variable name="FIREBASE_CRASHLYTICS_COLLECTION_ENABLED" value="false" />
    </plugin>
    
    <!-- ✅ AdMob Rewarded Ads (cordova-plugin-ads - survives background) -->
    <plugin name="cordova-plugin-ads" spec="2.0.5">
        <variable name="ADMOB_IOS_APP_ID" value="ca-app-pub-3940256099942544~1458002511" />
    </plugin>
    
    <!-- ✅ Biometric / Fingerprint Authentication for PIN Lock -->
    <plugin name="cordova-plugin-fingerprint-aio" spec="^5.0.1" />
    
    <!-- Note: Local Notifications removed due to SDK 34 compatibility issues -->
    
    <!-- ✅ Deep Links Configuration for Invite System -->
    <universal-links>
        <host name="accesschain.org" scheme="https">
            <path url="/" />
            <path url="/*" />
        </host>
        <host name="www.accesschain.org" scheme="https">
            <path url="/" />
            <path url="/*" />
        </host>
    </universal-links>
    
    <!-- ✅ Custom URL Scheme for accessnetwork:// links -->
    <!-- singleTop: keeps AdMob ad Activity alive when app goes to background -->
    <preference name="AndroidLaunchMode" value="singleTop" />
    
    <!-- ✅ Android Intent Filter for Deep Links -->
    <platform name="android">
        <config-file parent="/manifest/application/activity[@android:name='MainActivity']" target="AndroidManifest.xml" xmlns:android="http://schemas.android.com/apk/res/android">
            <!-- Intent filter for https://accesschain.org links -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="https" android:host="accesschain.org" />
            </intent-filter>
            <!-- Intent filter for custom scheme accessnetwork:// -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="accessnetwork" />
            </intent-filter>
        </config-file>
    </platform>

    <!-- ✅ iOS Associated Domains for Universal Links -->
    <platform name="ios">
        <config-file parent="com.apple.developer.associated-domains" target="*-Debug.plist">
            <array>
                <string>applinks:accesschain.org</string>
                <string>applinks:www.accesschain.org</string>
            </array>
        </config-file>
        <config-file parent="com.apple.developer.associated-domains" target="*-Release.plist">
            <array>
                <string>applinks:accesschain.org</string>
                <string>applinks:www.accesschain.org</string>
            </array>
        </config-file>
    </platform>
</widget>
